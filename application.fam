App(
    appid="morse_flipper",
    name="Morse Flipper",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="morse_flipper_fap",
    requires=["gui"],
    stack_size=4 * 1024,
    cdefines=[
        "MORSE_FLIPPER_FAP=1",
        'APP_BUILD_COMMIT=\\"MARKET\\"',
        'APP_BUILD_HOST=\\"MARKET\\"',
        'APP_BUILD_TIME=\\"MARKET\\"',
    ],
    sources=[
        "src/firmware/morse_flipper_fap.c",
        "src/firmware/morse_flipper_core.c",
        "src/firmware/morse_flipper_screen.c",
        "src/firmware/morse_flipper_status.c",
        "src/firmware/morse_flipper_audio_route.c",
        "src/firmware/cw_markdown_widget.c",
        "src/firmware/morse_flipper_help.c",
        "src/firmware/morse_flipper_app.c",
        "src/firmware/morse_flipper_flow.c",
        "src/firmware/morse_flipper_scenes.c",
        "src/firmware/morse_flipper_config.c",
        "src/firmware/morse_flipper_settings.c",
        "src/firmware/morse_flipper_settings_keying.c",
        "src/firmware/morse_flipper_settings_audio.c",
        "src/firmware/morse_flipper_settings_gpio.c",
        "src/firmware/morse_flipper_settings_training.c",
        "src/firmware/morse_flipper_settings_usb.c",
        "src/firmware/morse_flipper_keying.c",
        "src/firmware/morse_flipper_transport.c",
        "src/firmware/morse_flipper_input.c",
        "src/firmware/morse_flipper_runtime.c",
        "src/firmware/morse_flipper_session.c",
        "src/firmware/morse_flipper_rf_live.c",
        "src/firmware/morse_flipper_about.c",
        "src/firmware/morse_flipper_live_view.c",
        "src/firmware/morse_flipper_live_view_common.c",
        "src/firmware/morse_flipper_live_view_run.c",
        "src/firmware/morse_flipper_live_view_training.c",
        "src/firmware/morse_flipper_live_view_rf.c",
        "src/firmware/morse_flipper_live_view_ham.c",
        "src/firmware/morse_flipper_gpio.c",
        "src/firmware/morse_flipper_gpio_probe.c",
        "src/firmware/morse_flipper_ham_keyer.c",
        "src/firmware/morse_flipper_ham_runtime.c",
        "src/firmware/morse_flipper_audio_pwm.c",
        "src/firmware/morse_flipper_run_history.c",
        "src/firmware/morse_flipper_run_layout.c",
        "src/firmware/keyer.c",
        "src/firmware/cw.c",
        "src/firmware/morse_flipper_cw_token.c",
        "src/firmware/morse_flipper_cw_decoder.c",
        "src/firmware/pc_keys.c",
        "src/firmware/morse_flipper_radio.c",
        "src/firmware/morse_flipper_rf.c",
        "src/firmware/morse_flipper_rf_timing.c",
        "src/firmware/morse_flipper_straight_filter.c",
        "src/firmware/morse_flipper_straight_trainer.c",
        "src/firmware/morse_flipper_straight_runtime.c",
        "src/firmware/morse_flipper_tx_groups.c",
        "src/firmware/morse_flipper_tx_groups_runtime.c",
        "src/firmware/trainer.c",
        "src/firmware/trainer_files.c",
        "src/firmware/usb/*.c",
    ],
    targets=["f7"],
    fap_category="Tools",
    fap_version="0.1.75",
    fap_author="@yo3gnd",
    fap_weburl="https://github.com/yo3gnd/morse-flipper/",
    fap_description="Learn, practise, send, and experiment with Morse code on Flipper Zero.",
    fap_icon="morse-flipper.png",
    fap_file_assets="assets",
)
